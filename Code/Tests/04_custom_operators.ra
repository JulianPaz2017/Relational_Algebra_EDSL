// ============================================================
// 04_custom_operators.ar
// Tests de operadores custom (DEFINE/UNDEFINE)
// ============================================================

CREATE r {a INT, b INT};
CREATE s {a INT, b INT};
CREATE t {a INT, b INT};
CREATE u {a INT, b INT};

INSERT r (r.a, r.b) {
  (1, 2),
  (3, 4),
  (5, 6),
  (7, 8)
};

INSERT s (s.a, s.b) {
  (3, 4),
  (5, 6),
  (9, 10)
};

INSERT t (t.a, t.b) {
  (1, 2),
  (9, 10)
};

INSERT u (u.a, u.b) {
  (9, 10)
};

// ---- OPERADORES DERIVADOS CLÁSICOS ----

// Intersección: r ∩ s = r - (r - s)
DEFINE interseccion(x, y) = difference(x, difference(x, y));

// Probar intersección
interseccion(r, s);

// Intersección con sí misma (idempotente)
interseccion(r, r);

// Intersección vacía
interseccion(r, u);

// Diferencia simétrica: (r - s) ∪ (s - r)
DEFINE diff_simetrica(x, y) = union(difference(x, y), difference(y, x));

diff_simetrica(r, s);
diff_simetrica(r, r);

// ---- OPERADORES CON SELECCIÓN ----

// Seleccionar tuplas con primer atributo mayor a 3
DEFINE sel_mayor_tres(rel) = select{rel.a > 3}(rel);

sel_mayor_tres(r);
sel_mayor_tres(s);

// Operador con múltiples condiciones
DEFINE filtrar_rango(rel) = select{rel.a > 2 && rel.a < 8}(rel);

filtrar_rango(r);
filtrar_rango(s);

// ---- OPERADORES CON PROYECCIÓN ----

DEFINE solo_primer_attr(rel) = project{rel.a}(rel);

solo_primer_attr(r);
solo_primer_attr(s);

DEFINE ambos_attrs(rel) = project{rel.a, rel.b}(rel);

ambos_attrs(r);

// ---- OPERADORES COMPUESTOS ----

// Intersección y luego proyección
DEFINE interseccion_proyectada(x, y) = project{x.a}(interseccion(x, y));

interseccion_proyectada(r, s);

// Diferencia y selección
DEFINE diferencia_filtrada(x, y) = select{x.a > 2}(difference(x, y));

diferencia_filtrada(r, s);

// Operador que combina varias operaciones
DEFINE complejo(x, y) = 
  project{x.a}(
    select{x.a > 3}(
      difference(x, y)
    )
  );

complejo(r, s);

// ---- OPERADORES RECURSIVOS ----

// Operador que usa otros operadores custom
DEFINE elementos_exclusivos(x, y) = union(
  difference(x, y),
  difference(y, x)
);

elementos_exclusivos(r, s);
elementos_exclusivos(r, t);

// Operador que usa intersección
DEFINE elementos_comunes_mayores(x, y) = 
  select{x.a > 3}(interseccion(x, y));

elementos_comunes_mayores(r, s);

// ---- OPERADORES CON RENAME ----

DEFINE auto_join(rel) = 
  cartesian_product(
    rename{r1}(rel),
    rename{r2}(rel)
  );

auto_join(r);

// ---- UNDEFINE ----

// Deshacer operador
UNDEFINE solo_primer_attr;

// ---- REDEFINIR OPERADOR ----

// Redefinir intersección con otra implementación (misma)
DEFINE interseccion(x, y) = difference(x, difference(x, y));

interseccion(r, s);

// ---- DROP ----

DROP t;
